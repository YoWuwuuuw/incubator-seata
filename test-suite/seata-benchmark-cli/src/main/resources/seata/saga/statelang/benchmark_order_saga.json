{
  "Name": "benchmarkOrderSaga",
  "Comment": "Benchmark order saga state machine with inventory reservation and payment",
  "StartState": "ReserveInventory",
  "Version": "1.0.0",
  "States": {
    "ReserveInventory": {
      "Type": "ServiceTask",
      "ServiceName": "inventoryService",
      "ServiceMethod": "reserveInventory",
      "CompensateState": "ReleaseInventory",
      "Input": [
        {
          "productId": "$.productId",
          "quantity": "$.quantity"
        }
      ],
      "Output": {
        "inventoryResult": "$.#root"
      },
      "Catch": [
        {
          "Exceptions": ["java.lang.Exception"],
          "Next": "CompensationTrigger"
        }
      ],
      "Next": "DebitPayment"
    },
    "ReleaseInventory": {
      "Type": "ServiceTask",
      "ServiceName": "inventoryService",
      "ServiceMethod": "releaseInventory",
      "IsForCompensation": true,
      "Input": [
        {
          "productId": "$.productId",
          "quantity": "$.quantity"
        }
      ]
    },
    "DebitPayment": {
      "Type": "ServiceTask",
      "ServiceName": "paymentService",
      "ServiceMethod": "debitPayment",
      "CompensateState": "RefundPayment",
      "Input": [
        {
          "accountId": "$.accountId",
          "amount": "$.amount"
        }
      ],
      "Output": {
        "paymentResult": "$.#root"
      },
      "Catch": [
        {
          "Exceptions": ["java.lang.Exception"],
          "Next": "CompensationTrigger"
        }
      ],
      "Next": "CreateOrder"
    },
    "RefundPayment": {
      "Type": "ServiceTask",
      "ServiceName": "paymentService",
      "ServiceMethod": "refundPayment",
      "IsForCompensation": true,
      "Input": [
        {
          "accountId": "$.accountId",
          "amount": "$.amount"
        }
      ]
    },
    "CreateOrder": {
      "Type": "ServiceTask",
      "ServiceName": "orderService",
      "ServiceMethod": "createOrder",
      "CompensateState": "CancelOrder",
      "Input": [
        {
          "userId": "$.userId",
          "productId": "$.productId",
          "quantity": "$.quantity",
          "amount": "$.amount"
        }
      ],
      "Output": {
        "orderResult": "$.#root"
      },
      "Catch": [
        {
          "Exceptions": ["java.lang.Exception"],
          "Next": "CompensationTrigger"
        }
      ],
      "Next": "Succeed"
    },
    "CancelOrder": {
      "Type": "ServiceTask",
      "ServiceName": "orderService",
      "ServiceMethod": "cancelOrder",
      "IsForCompensation": true,
      "Input": [
        {
          "orderId": "$.orderResult.orderId",
          "userId": "$.userId"
        }
      ]
    },
    "CompensationTrigger": {
      "Type": "CompensationTrigger",
      "Next": "Fail"
    },
    "Succeed": {
      "Type": "Succeed"
    },
    "Fail": {
      "Type": "Fail",
      "ErrorCode": "SAGA_COMPENSATION",
      "Message": "Saga compensation triggered"
    }
  }
}
